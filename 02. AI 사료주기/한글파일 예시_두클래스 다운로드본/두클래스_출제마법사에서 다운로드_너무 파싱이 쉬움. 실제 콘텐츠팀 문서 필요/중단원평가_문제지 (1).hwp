  <TEXT CharShape="16">
    <CHAR>지완이와 수린이를 포함한 학생 </CHAR>
  </TEXT>
  <TEXT CharShape="19">
    <EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60">
