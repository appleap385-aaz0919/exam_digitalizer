</SHAPEOBJECT>
<SCRIPT>7</SCRIPT>
</EQUATION>
</TEXT>
  <TEXT CharShape="16">
    <CHAR>명은 연주회 체험 활동에 참여하여 일렬로 배열된 좌석의 입장권 </CHAR>
  </TEXT>
  <TEXT CharShape="19">
    <EQUATION BaseLine="85" BaseUnit="1100" LineMode="false" TextColor="0" Version="Equation Version 60">
<SHAPEOBJECT InstId="1621055629" Lock="false" NumberingType="Equation" TextFlow="BothSides" TextWrap="Square" ZOrder="1">
